{
  "version": "2026-04-30-r5",
  "scope": "official_strategy_evidence",
  "consensus_sources": [
    "consensus_audit_report_20260430.md",
    "consensus_audit_round2.md",
    "consensus_audit_r3.md",
    "consensus_audit_r4.md",
    "consensus_audit_r5.md"
  ],
  "default_walk_forward": {
    "data_start_date": "2005-01-01",
    "train_window_definition": "rolling_calendar_years_ending_at_train_end",
    "train_window_years": 5,
    "train_window_trading_days_approx": 1260,
    "rebalance_interval_trading_days": 21,
    "model_refit_interval_trading_days": 63,
    "predictions_between_refits": "use_latest_frozen_model_version_with_valid_train_end_rule",
    "first_oot_start_rule": "computed_from_exchange_calendar_after_train_window_and_purge_requirements",
    "first_oot_start_must_be_reported": true,
    "expected_oot_steps_rule": "floor((last_non_holdout_trade_date - first_oot_start_trade_date + 1) / rebalance_interval_trading_days)",
    "actual_oot_step_count_must_be_reported": true,
    "min_oot_steps": 24,
    "min_oot_steps_role": "minimum_acceptance_gate_not_total_walk_forward_count",
    "purge_days": 40,
    "purge_multiplier": 3,
    "embargo_days": 10,
    "holdout_required": true,
    "holdout_window": "last_12_months",
    "holdout_trading_days_approx": 252,
    "holdout_excluded_from_oot_step_count": true,
    "train_end_rule": "prediction_start_trade_date_minus_purge_days",
    "annual_analysis_required": true,
    "market_regime_analysis_required": true
  },
  "label_rules": {
    "purge_days_min_rule": "max(label_horizon_trading_days * default_walk_forward.purge_multiplier, default_walk_forward.purge_days)",
    "qant_10d_legacy_note": "Earlier qant deep-dive experiments used purge_days=10 to isolate the known 10-day label leak. New official evidence must use the stricter Round 5/round2 rule max(horizon*3,40) unless a narrower diagnostic run is explicitly labeled as exploratory and excluded from keep decisions.",
    "purge_sensitivity_days": [40, 60, 80],
    "purge_sensitivity_bootstrap_block_days": [10, 21, 40]
  },
  "accepted_validation_modes": [
    "chronological_walk_forward",
    "purged_walk_forward",
    "blocked_random_with_purge_embargo_for_diagnostic_only",
    "combinatorial_purged_cv_for_sensitivity"
  ],
  "rejected_validation_modes": [
    "naive_random_8_2_as_final_evidence",
    "validation_with_oot_label_overlap",
    "benchmark_or_cost_changes_without_baseline_rerun"
  ],
  "overfit_audit_required": [
    "deflated_sharpe_ratio",
    "probability_of_backtest_overfitting",
    "holdout_window",
    "parameter_perturbation",
    "annual_and_market_regime_stability",
    "false_discovery_rate_if_factor_count_gt_20"
  ],
  "s1_acceptance_gate": {
    "gate_logic": "hard_gate_all_required",
    "rank_ic_t_stat_min": 1.65,
    "ic_t_stat_method": "newey_west_hac_adjusted",
    "rank_ic_t_stat_uses_hac": true,
    "newey_west_bandwidth_selection": "deterministic_rule_of_thumb",
    "newey_west_bandwidth_rule": "lag_floor_4_times_n_over_100_power_2_over_9_min_1",
    "bootstrap_p_max": 0.1,
    "stat_gate_logic": "rank_ic_t_stat >= rank_ic_t_stat_min OR block_bootstrap_p < bootstrap_p_max",
    "block_unit": "trading_days",
    "block_bootstrap_unit": "trading_days",
    "block_bootstrap_days": 21,
    "block_bootstrap_days_rule": "max(label_horizon_trading_days, default_walk_forward.rebalance_interval_trading_days)",
    "block_bootstrap_days_default_for_20d_label": 21,
    "block_bootstrap_sensitivity_days": [10, 21, 40],
    "bootstrap_samples_min": 5000,
    "fdr_required_if_factor_count_gt": 20,
    "holdout_window": "last_12_months",
    "holdout_sharpe_min": 0.0,
    "holdout_direction_consistent": true,
    "annual_turnover_max": 3.0,
    "cost_after_excess_return_positive": true,
    "capacity_report_required": true,
    "limit_lock_report_required": true
  },
  "data_gap_policy": {
    "valuation_daily_2026_gap": {
      "gap_start": "2026-01-05",
      "gap_end": "2026-02-05",
      "observed_missing_trading_days": 24,
      "feature_policy": "bounded_forward_fill_by_asset_for_slow_moving_valuation_features_only",
      "max_forward_fill_trading_days": 25,
      "forbidden_uses": [
        "labels",
        "returns",
        "execution_prices",
        "performance_accounting"
      ],
      "sensitivity_required": true,
      "report_missing_mask_required": true
    }
  },
  "capacity_policy": {
    "adv_source": "tradability_daily_enriched.amount",
    "adv_unit": "turnover_amount",
    "new_listing_adv_insufficient_if_listing_age_lt_trading_days": 20,
    "adv_min_valid_bar_ratio": 0.8,
    "bar_absent_amount_policy": "exclude_from_valid_adv_day_count_and_report_separately",
    "adv_windows_trading_days": [20, 60, 120],
    "amount_coverage_report_required": true
  },
  "benchmark_audit": {
    "coverage_assets_report_required": true,
    "early_proxy_warning_before_year": 2005,
    "s1_main_window_starts": "2005-01-01",
    "pre_2005_data_role": "sensitivity_only",
    "known_local_coverage_note": "CN_A_ALL_EQW_PROXY coverage_assets: 1990 range 1-5; 2005 min/median/max about 1164/1315/1342; 2024 median about 5342",
    "non_data_status_files_must_be_ignored_by_loaders": true
  },
  "exploratory_tracking": {
    "direction_consistency_min": 0.65,
    "recent_consistency_steps": 6,
    "recent_consistency_min": 4,
    "cooldown_months_min": 6,
    "cooldown_start": "first_entered_exploratory_tracking_date",
    "post_cooldown_reentry_allowed": true,
    "post_cooldown_action": "requeue_to_s1_candidate_if_recent_direction_consistency_passes",
    "post_cooldown_recent_consistency_steps": 6,
    "post_cooldown_recent_consistency_min": 4,
    "portfolio_allowed": false,
    "complete_record_required": true,
    "counts_toward_attempt_count": true
  },
  "regime_alert": {
    "ic_rolling_window_days": 20,
    "alert_only_before_validation": true,
    "position_change_requires_walk_forward_validation": true,
    "ic_half_life_monitoring_required": true,
    "ic_half_life_unit": "quarters",
    "ic_half_life_gate": false,
    "ic_half_life_risk_bands_quarters": {
      "high_risk_lt": 4,
      "medium_risk_gte": 4,
      "medium_risk_lte": 8,
      "low_risk_gt": 8
    }
  },
  "factor_processing": {
    "orthogonalization": {
      "enabled_for_composite_models": true,
      "method": "gram_schmidt",
      "input": "cross_sectional_zscore_factors_after_winsorization_and_neutralization_if_used",
      "ordering": "descending_in_sample_icir_from_training_window_only",
      "outputs_required": [
        "factor_correlation_matrix_before",
        "factor_correlation_matrix_after",
        "orthogonalization_order",
        "coverage_and_missingness_report"
      ],
      "applies_between": "after_raw_single_factor_equal_weight_and_icir_baselines_before_ridge_elasticnet_models",
      "oot_data_must_not_influence_ordering": true
    },
    "seasonality_policy": {
      "default": "five_year_training_window_covers_complete_annual_cycles",
      "month_dummies_default": false,
      "month_dummies_allowed_only_as": "preregistered_s3_or_sensitivity_analysis"
    }
  },
  "training_weighting": {
    "status": "r5_single_track_weighting_policy",
    "equal_weight_control_required": true,
    "default_scheme": "exponential_decay",
    "default_half_life_months": 12,
    "allowed_half_life_sensitivity_months": [12, 18],
    "optional_research_half_life_months": [6, 24, 36],
    "selection_rule": "default_12m_primary_and_18m_preregistered_sensitivity; any alternate half_life_must_be_selected_by_nested_training_only_not_oot_or_holdout",
    "sample_weight_formula": "weight = 2 ** (-age_trading_days / (half_life_months * 21))",
    "weight_normalization": "normalize_within_each_training_step_mean_1",
    "supported_interfaces_required": [
      "sample_weight_for_sklearn_lightgbm_xgboost",
      "weighted_regression_or_explicit_weighted_loss_for_linear_models"
    ],
    "rebalance_interval_trading_days": 21,
    "model_refit_interval_trading_days": 63,
    "model_refit_sensitivity_intervals_trading_days": [21, 63],
    "predictions_between_refits": "use_latest_frozen_model_version_with_valid_train_end_rule",
    "oot_and_holdout_selection_forbidden": true,
    "report_equal_weight_vs_decay_required": true
  },
  "universe_audit": {
    "required_before_panel_keep": true,
    "default_universe": "universe_daily.in_factor_research_universe",
    "known_rule": "can_trade_close_based AND listing_age_trading_days >= 60 AND NOT is_risk_warning_pit",
    "must_confirm": [
      "no_current_stock_list_backfill_for_history",
      "st_suspend_limit_fields_are_point_in_time_or_disclosed_as_source_gap",
      "historical_delisted_assets_are_not_dropped",
      "available_at_and_decision_time_are_not_after_execution_time",
      "universe_rule_version_or_source_hash_is_recorded"
    ]
  },
  "institutional_risk_checks": {
    "limit_up_down_exclusion_ic_comparison": true,
    "registration_reform_period_break_analysis": true,
    "liquidity_dry_up_stress_ic_analysis": true,
    "stress_windows_must_be_preregistered": true
  },
  "concept_shift": {
    "status": "required_data_driven_diagnostic_only",
    "does_not_replace_single_track_baseline": true,
    "default_response": "no_same_step_model_switch_alpha_change_or_threshold_change",
    "shift_types": [
      "covariate_shift",
      "concept_shift"
    ],
    "default_alert_state_machine": {
      "input_series": "matured_walk_forward_ic_or_factor_return_series_only",
      "window_steps": 6,
      "yellow_if_negative_steps_in_last_window_gte": 4,
      "red_if_consecutive_negative_steps": 6,
      "yellow_action": "flag_candidate_and_require_equal_weight_vs_decay_and_segment_report",
      "red_action": "quarantine_new_keep_or_promotion_until_next_pre_registered_revalidation_passes",
      "current_step_action_forbidden": true,
      "human_review_required": false
    },
    "optional_diagnostic_tests": {
      "break_tests": [
        "chow_on_matured_ic_or_factor_return_series_for_reporting_only"
      ],
      "streaming_change_monitors": [
        "adwin_or_page_hinkley_on_matured_prequential_loss_or_ic_for_reporting_only",
        "bayesian_online_changepoint_detection_on_matured_ic_for_reporting_only"
      ],
      "covariate_shift_monitors": [
        "feature_distribution_psi_or_mmd_available_before_prediction",
        "market_state_distribution_shift_available_before_prediction"
      ],
      "crowding_monitors": [
        "factor_return_turnover_correlation",
        "left_tail_skew_or_cvar",
        "factor_return_autocorrelation"
      ],
      "tests_are_not_keep_gates": true
    },
    "detector_inputs_must_be_matured_before_prediction": true,
    "current_oot_labels_forbidden_for_current_step_alpha": true,
    "pre_registered_stress_segments": [
      "2024-05_to_2024-08",
      "2024-09_to_2025-02",
      "2025-03_to_latest_non_holdout"
    ],
    "oot_segments": {
      "role": "descriptive_report_only_not_statistical_gate",
      "segments": [
        {
          "name": "post_quant_crowding_recovery",
          "start": "2024-05-01",
          "end": "2024-08-31"
        },
        {
          "name": "policy_adjustment_period",
          "start": "2024-09-01",
          "end": "2025-02-28"
        },
        {
          "name": "new_equilibrium_period",
          "start": "2025-03-01",
          "end": "latest_non_holdout"
        }
      ]
    },
    "oot_segment_role": "descriptive_report_only_not_statistical_keep_gate",
    "alert_role": "diagnostic_and_quarantine_state_not_standalone_keep_gate"
  },
  "adaptive_training": {
    "status": "deprecated_by_r5",
    "allowed": false,
    "forbidden_schemes": [
      "two_track_track_a_track_b",
      "dynamic_alpha_selected_from_oot",
      "online_track_b_micro_update",
      "same_step_label_feedback"
    ],
    "reason": "unnecessary_complexity_and_leakage_or_overfit_risk",
    "replacement": "single_track_rolling_5y_with_pre_registered_exponential_decay_weighting",
    "reconsideration_conditions": [
      "new_protocol_written_before_experiment",
      "nested_training_validation_only",
      "same_audits_as_s1_keep",
      "no_current_oot_or_holdout_feedback"
    ]
  },
  "s1_preconditions": {
    "blocking_before_s1_main_evidence": [
      "universe_daily_construction_audit",
      "walk_forward_calendar_with_actual_oot_step_count",
      "train_cutoff_purge_embargo_validation",
      "validation_params_hash"
    ],
    "blocking_before_factor_keep": [
      "valuation_gap_sensitivity_for_valuation_features",
      "benchmark_coverage_assets_audit",
      "adv_insufficient_new_listing_flags",
      "equal_weight_control_vs_exponential_decay_report"
    ],
    "not_blocking_s1_main_baseline": [
      "optional_adwin_bocpd_diagnostics",
      "optional_decay_half_life_research_grid_outside_keep_decision"
    ]
  },
  "s1_required_diagnostics": {
    "limit_lock_excluded_ic_comparison_required": true,
    "registration_regime_segment_analysis_required": true,
    "liquidity_dry_up_day_ic_analysis_required": true
  },
  "factor_decay_monitoring": {
    "required_in_s1_report": true,
    "half_life_unit": "quarter",
    "half_life_definition": "quarters_for_rolling_ic_to_fall_from_peak_to_50_percent",
    "risk_bands": {
      "high_risk_lt_quarters": 4,
      "medium_risk_quarters": [4, 8],
      "low_risk_gt_quarters": 8
    },
    "gate_role": "report_only_not_s1_hard_gate"
  }
}
